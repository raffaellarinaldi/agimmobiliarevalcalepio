<div id="contact">
	<div class="section">
		<div class="row justify-content-center footer-cta" data-aos="fade-up">
			<div class="col-lg-7 mx-auto text-center">
				<h2 class="mb-4">Passa a trovarci!</h2>
				<p class="lead">Prenota un appuntamento oggi stesso, ti aiuteremo a trovare la casa dei tuoi sogni.</p>
				<p><a href="tel:{{ site.phone.land }}" target="_blank" class="btn btn-primary text-white py-3 px-4"><span class="icon-phone me-2"></span>Chiama ora</a></p>
			</div>
		</div>
	</div>
	<div class="m-0 p-0" style="line-height:0">
		<iframe style="outline:0;border:0" src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2789.1614212673803!2d9.9097659!3d45.64758!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47816704f32c9123%3A0x8cbfac0caec16b8!2sAgenzia%20immobiliare%20Valcalepio!5e0!3m2!1sit!2sit!4v1711383379182!5m2!1sit!2sit" width="100%" height="450" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
	</div>
	<div class="site-footer bg-light text-black-50">
		<div class="container">
			<div class="row">
				<div class="col-lg-4">
					<div class="widget">
						<h3>Contatti</h3>
						<address>{{ site.address }}</address>
						<ul class="list-unstyled links">
							<li><a href="tel://{{ site.phone.land }}">{{ site.phone.land }}</a></li>
							<li><a href="tel://{{ site.phone.land }}">{{ site.phone.mobile }}</a></li>
							<li><a href="mailto:{{ site.email }}">{{ site.email }}</a></li>
							<li><a href="mailto:{{ site.pec }}">{{ site.pec }}</a></li>
						</ul>
						<p class="m-0">Lun 14:00–19:30</p><p class="m-0">Mar–Ven 08:30–12:30 14:00–19:30</p><p class="m-0">Sab 08:30–12:30</p>
					</div>
				</div>
				<div class="col-lg-4">
					<div class="widget">
						<h3>Aree</h3>
						<ul class="list-unstyled float-start links">
							<li>Adrara S. Martino</li>
							<li>Adrara S. Rocco</li>
							<li>Bergamo</li>
							<li>Bolgare</li>
							<li>Capriolo</li>
							<li>Castelli Calepio</li>
							<li>Erbusco</li>
							<li>Gandosso</li>
						</ul>
						<ul class="list-unstyled float-start links">
							<li>Grumello d/M</li>
							<li>Lovere</li>
							<li>Palazzolo s/O</li>
							<li>Paratico</li>
							<li>Predore</li>
							<li>Sarnico</li>
							<li>Telgate</li>
							<li>Villongo</li>
						</ul>
					</div>
				</div>
				<div class="col-lg-4">
					<div class="widget">
						<h3>Collegamenti</h3>
						<ul class="list-unstyled links">
							<li><a href="https://agenziavalcalepio.it" target="_blank">Sito principale</a></li>
							<li><a href="https://www.iubenda.com/privacy-policy/62197139.pdf">Privacy Policy</a></li>
							<li><a href="https://www.mlsagentre.it/sito/43461">MlsAgentRE</a></li>
						</ul>
						<ul class="list-unstyled social">
							{% for network in site.network %}
								<li><a href="{{ network.link }}" target="_blank" rel="nofollow noreferrer noopener"><span class="icon-{{ network.icon }}"></span></a></li>
							{% endfor %}
						</ul>
					</div>
				</div>
			</div>
			<div class="row mt-5">
				<div class="col-12 text-center">
					<p>Copyright &copy; {% year %} {{ site.title }}. All Rights Reserved. &mdash; Designed with love by <a href="https://untree.co" target="_blank" rel="nofollow noreferrer noopener">Untree.co</a> & developed by <a href="{{ site.credits.url }}" target="_blank" rel="noopener">{{ site.credits.name }}</a></p>
				</div>
			</div>
		</div>
	</div>
</div>
